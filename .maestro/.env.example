# Copy to .maestro/.env and fill in for your environment, then pass with
#   maestro test --env-file .maestro/.env .maestro
#
# .maestro/.env is git-ignored (see .maestro/.gitignore). Never commit real
# account credentials.

# ── App under test ───────────────────────────────────────────────────────────
# Use the STAGING build for E2E so you hit the test/dev Convex backend and the
# "Test Environment" chip is shown. Production id is au.org.sow.theshed.
APP_ID=au.org.sow.theshed.staging

# Android package is the same string; iOS uses the bundle identifier above.

# ── Deep-link scheme ─────────────────────────────────────────────────────────
# theshedmobile for production, theshedmobilestaging for the staging build.
SCHEME=theshedmobilestaging

# ── Test accounts (Google / sow.org.au) ──────────────────────────────────────
# Each must already be provisioned in the test backend with the noted roles.
STAFF_EMAIL=e2e-staff@sow.org.au
STAFF_PASSWORD=

# The admin account is also the HOD approver for the seeded "Data and IT" dept.
APPROVER_EMAIL=e2e-admin@sow.org.au
APPROVER_PASSWORD=

ADMIN_EMAIL=e2e-admin@sow.org.au
ADMIN_PASSWORD=

FINANCE_EMAIL=e2e-finance@sow.org.au
FINANCE_PASSWORD=

# Director (seeded with the Director role) — approves ≥ threshold requests.
DIRECTOR_EMAIL=e2e-director@sow.org.au
DIRECTOR_PASSWORD=

CAMPUS_LEADER_EMAIL=e2e-campus@sow.org.au
CAMPUS_LEADER_PASSWORD=

# Account with NO profile assigned (drives the welcome / no-profile card).
# Intentionally NOT given a profile by devE2E:setup.
NOPROFILE_EMAIL=e2e-noprofile@sow.org.au
NOPROFILE_PASSWORD=

# A person email that exists in the directory (for /person/[email] deep links).
KNOWN_PERSON_EMAIL=e2e-staff@sow.org.au

# ── Auth bypass (dev/test deployments only — see README) ──────────────────────
# Must equal E2E_AUTH_SECRET set on the E2E Convex deployment. When set, the
# Maestro sign-in dispatcher uses the bypass instead of Google OAuth.
E2E_SECRET=

# Non-destructive launch defaults are safe for a dev client; CI passes
# CLEAR_STATE=true for isolation.
DEV_CLIENT=true
