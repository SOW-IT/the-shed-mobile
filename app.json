{
  "expo": {
    "name": "The SHED",
    "slug": "the-shed-mobile",
    "version": "1.1.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "theshedmobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "au.org.sow.theshed",
      "supportsTablet": true,
      "associatedDomains": [
        "applinks:the-shed-web.vercel.app"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "au.org.sow.theshed",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "the-shed-web.vercel.app"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#F5F3E3",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F5F3E3",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 140,
          "dark": {
            "backgroundColor": "#0F2523",
            "image": "./assets/images/splash-icon-dark.png"
          }
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow THE SHED to access your photos to set a profile picture."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "xtectras-team",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ee729ed9-3432-4e98-a8d3-dbc089a3d4ec"
      }
    }
  }
}
