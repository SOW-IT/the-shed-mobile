# dependencies
node_modules/

.idea*

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.keystore
*.p8
*.p12
*.key
*.mobileprovision

# EAS / mobile credentials & secrets — never commit
*credentials.json
google-services.json
GoogleService-Info.plist
*-service-account*.json
play-service-account.json

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

example

# generated native folders
/ios
/android

.vercel

# test coverage reports
/coverage
/coverage-tmp

# Local prod data snapshot (contains PII) — never commit
the-shed-prod-snapshot.zip
*-snapshot.zip

# Generated App Store screenshots (regenerable; contain real account data)
/app-store-screenshots/
